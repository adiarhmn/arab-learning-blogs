---
const SITE = import.meta.env.SITE;
type NavItems = {
    label: string;
    href?: string;
    variant?: 'button';
    children?: {
        label: string;
        href?: string;
        children?: {
            label: string;
            href?: string;
        }[];
    }[];
}[];
const navItems: NavItems = [
    { label: 'Home', href: '/' },
    {
        label: 'Bahasa Arab',
        children: [
            {
                label: 'Durusullughah',
                children: [
                    { label: 'Jilid 1', href: '/durusullughah/jilid-1' },
                    { label: 'Jilid 2', href: '/durusullughah/jilid-2' },
                    { label: 'Jilid 3', href: '/durusullughah/jilid-3' },
                    { label: 'Jilid 4', href: '/durusullughah/jilid-4' },
                ],
            },
            {
                label: 'Jurmiyyah',
                children: [
                    { label: 'Matan Jurmiyyah', href: '/jurmiyyah/matan' },
                    { label: 'Tuhfatus Saniyah', href: '/jurmiyyah/tuhfatus-saniyah' },
                    { label: 'Al Mumti', href: '/jurmiyyah/al-mumti' },
                    { label: 'Mutammimah', href: '/jurmiyyah/mutammimah' },
                ],
            },
            {
                label: 'ABY',
                children: [
                    { label: 'ABY 1 A', href: '/aby/aby-1-a' },
                    { label: 'ABY 1 B', href: '/aby/aby-1-b' },
                    { label: 'ABY 2 A', href: '/aby/aby-2-a' },
                    { label: 'ABY 2 B', href: '/aby/aby-2-b' },
                ],
            },
        ],
    },
    { label: 'Tafsir', href: '/tafsir' },
    { label: 'Tentang Fuad', href: '/about', variant: 'button' },
];

console.log(SITE);
---

<nav class="sticky top-0 z-[100] bg-white/95 backdrop-blur-md border-b border-gray-100">
    <div class="container mx-auto px-6 h-20 flex justify-between items-center relative z-[110] bg-white">
        <!-- Logo -->
        <a href="/" class="flex items-center gap-3 group">
            <img class="w-10 h-10 rounded-lg" src={SITE + 'logo.png'} alt="Logo" />
            <div class="flex flex-col">
                <span class="text-lg font-bold text-[#0f172a] leading-none font-aref-ruqaa">Fuad Rahman</span>
                <span class="text-[10px] uppercase tracking-[0.2em] text-[#065f46] font-bold">Bahasa Arab & Tafsir</span
                >
            </div>
        </a>

        <!-- Desktop Navigation -->
        <div class="hidden lg:flex items-center gap-1">
            {
                navItems.map((item) => (
                    <div class="relative group px-1">
                        {item.children ? (
                            <>
                                <button class="flex items-center gap-1.5 px-4 py-2 text-slate-600 font-medium hover:text-[#065f46] hover:bg-emerald-50 rounded-lg transition-all">
                                    {item.label}
                                    <svg
                                        class="w-4 h-4 text-slate-400 group-hover:rotate-180 transition-transform"
                                        fill="none"
                                        stroke="currentColor"
                                        viewBox="0 0 24 24"
                                    >
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M19 9l-7 7-7-7"
                                        />
                                    </svg>
                                </button>

                                <div class="absolute left-0 mt-1 w-56 bg-white rounded-xl shadow-2xl border border-gray-100 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 translate-y-2 group-hover:translate-y-0 p-2">
                                    {item.children.map((child) => (
                                        <div class="relative group/sub">
                                            {child.children ? (
                                                <>
                                                    <div class="flex items-center justify-between px-3 py-2.5 rounded-lg text-slate-600 hover:text-[#065f46] hover:bg-emerald-50 cursor-pointer transition-colors">
                                                        <span class="font-medium">{child.label}</span>
                                                        <svg
                                                            class="w-4 h-4"
                                                            fill="none"
                                                            stroke="currentColor"
                                                            viewBox="0 0 24 24"
                                                        >
                                                            <path
                                                                stroke-linecap="round"
                                                                stroke-linejoin="round"
                                                                stroke-width="2"
                                                                d="M9 5l7 7-7 7"
                                                            />
                                                        </svg>
                                                    </div>
                                                    <div class="absolute left-full top-0 ml-1 w-56 bg-white rounded-xl shadow-2xl border border-gray-100 opacity-0 invisible group-hover/sub:opacity-100 group-hover/sub:visible transition-all duration-200 translate-x-2 group-hover/sub:translate-x-0 p-2">
                                                        {child.children.map((grandchild) => (
                                                            <a
                                                                href={grandchild.href}
                                                                class="block px-3 py-2.5 rounded-lg text-slate-600 font-medium hover:text-[#065f46] hover:bg-emerald-50 transition-colors"
                                                            >
                                                                {grandchild.label}
                                                            </a>
                                                        ))}
                                                    </div>
                                                </>
                                            ) : (
                                                <a
                                                    href={child.href}
                                                    class="block px-3 py-2.5 rounded-lg text-slate-600 font-medium hover:text-[#065f46] hover:bg-emerald-50 transition-colors"
                                                >
                                                    {child.label}
                                                </a>
                                            )}
                                        </div>
                                    ))}
                                </div>
                            </>
                        ) : (
                            <a
                                href={item.href}
                                class={
                                    item.variant === 'button'
                                        ? 'ml-4 bg-[#065f46] text-white px-5 py-2.5 rounded-xl font-bold hover:bg-[#044a37] transition-colors shadow-lg shadow-emerald-900/10'
                                        : 'px-4 py-2 text-slate-600 font-medium hover:text-[#065f46] hover:bg-emerald-50 rounded-lg transition-all'
                                }
                            >
                                {item.label}
                            </a>
                        )}
                    </div>
                ))
            }
        </div>

        <!-- Mobile Toggle -->
        <button id="mobile-toggle" class="lg:hidden p-2 text-slate-600 hover:text-[#065f46] transition-colors">
            <svg id="icon-open" class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"
                ><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7"
                ></path></svg
            >
            <svg id="icon-close" class="w-8 h-8 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"
                ><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"
                ></path></svg
            >
        </button>
    </div>

    <!-- Mobile Menu: Dropdown Style -->
    <div
        id="mobile-menu"
        class="hidden absolute top-20 left-0 w-full h-[calc(100vh-80px)] bg-white border-t border-gray-100 overflow-y-auto z-[105] shadow-2xl"
    >
        <div class="p-6 pb-20">
            <div class="flex flex-col gap-4">
                {
                    navItems.map((item) => (
                        <div class="border-b border-slate-50 last:border-0 pb-4">
                            {item.children ? (
                                <div>
                                    <span class="text-xs font-bold text-slate-400 uppercase tracking-widest px-2">
                                        {item.label}
                                    </span>
                                    <div class="mt-4 space-y-6">
                                        {item.children.map((child) => (
                                            <div class="px-2">
                                                <span class="block text-slate-900 font-bold mb-3 text-sm">
                                                    {child.label}
                                                </span>
                                                <div class="grid grid-cols-2 gap-2">
                                                    {child.children?.map((grandchild) => (
                                                        <a
                                                            href={grandchild.href}
                                                            class="bg-slate-50 p-4 rounded-xl text-slate-700 text-sm font-medium active:bg-emerald-50 active:text-[#065f46] border border-transparent active:border-emerald-100 transition-all"
                                                        >
                                                            {grandchild.label}
                                                        </a>
                                                    ))}
                                                    {!child.children && (
                                                        <a
                                                            href={child.href}
                                                            class="col-span-2 bg-slate-50 p-4 rounded-xl text-slate-700 text-sm font-medium active:bg-emerald-50 active:text-[#065f46] border border-transparent active:border-emerald-100 transition-all"
                                                        >
                                                            {child.label}
                                                        </a>
                                                    )}
                                                </div>
                                            </div>
                                        ))}
                                    </div>
                                </div>
                            ) : (
                                <a
                                    href={item.href}
                                    class={`block py-2 text-lg font-bold px-2 ${item.variant === 'button' ? 'text-[#065f46]' : 'text-slate-900'}`}
                                >
                                    {item.label}
                                </a>
                            )}
                        </div>
                    ))
                }
            </div>

            <div class="mt-8 p-6 bg-emerald-50 rounded-2xl border border-emerald-100">
                <p class="text-sm text-emerald-800 font-bold mb-1">Pusat Belajar Fuad Rahman</p>
                <p class="text-xs text-emerald-600 leading-relaxed">
                    Akses semua materi Durusullughah dan Jurmiyyah dengan mudah.
                </p>
            </div>
        </div>
    </div>
</nav>

<script>
    function initNav() {
        const toggle = document.getElementById('mobile-toggle');
        const menu = document.getElementById('mobile-menu');
        const iconOpen = document.getElementById('icon-open');
        const iconClose = document.getElementById('icon-close');

        if (toggle && menu && iconOpen && iconClose) {
            toggle.onclick = (e) => {
                e.preventDefault();
                const isHidden = menu.classList.contains('hidden');

                if (isHidden) {
                    menu.classList.remove('hidden');
                    iconOpen.classList.add('hidden');
                    iconClose.classList.remove('hidden');
                    document.body.style.overflow = 'hidden';
                } else {
                    menu.classList.add('hidden');
                    iconOpen.classList.remove('hidden');
                    iconClose.classList.add('hidden');
                    document.body.style.overflow = '';
                }
            };

            // Close menu on link click
            const links = menu.querySelectorAll('a');
            links.forEach((link) => {
                link.onclick = () => {
                    menu.classList.add('hidden');
                    iconOpen.classList.remove('hidden');
                    iconClose.classList.add('hidden');
                    document.body.style.overflow = '';
                };
            });
        }
    }

    initNav();
    document.addEventListener('astro:after-swap', initNav);
</script>
