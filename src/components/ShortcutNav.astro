---
type Items = {
    label: string;
    href: string;
    icon: string;
    image?: string;
}[];

type Categories = {
    title: string;
    items: Items;
}[];

const categories: Categories = [
    {
        title: 'Durusullughah',
        items: [
            {
                label: 'Jilid 1',
                href: '/durusullughah/jilid-1',
                icon: '1',
                image: '/menu-images/durusullughah/jilid-1.png',
            },
            {
                label: 'Jilid 2',
                href: '/durusullughah/jilid-2',
                icon: '2',
                image: '/menu-images/durusullughah/jilid-2.png',
            },
            {
                label: 'Jilid 3',
                href: '/durusullughah/jilid-3',
                icon: '3',
                image: '/menu-images/durusullughah/jilid-3-4.png',
            },
            {
                label: 'Jilid 4',
                href: '/durusullughah/jilid-4',
                icon: '4',
                image: '/menu-images/durusullughah/jilid-3-4.png',
            },
        ],
    },
    {
        title: 'Jurmiyyah',
        items: [
            {
                label: 'Matan Jurmiyyah',
                href: '/jurmiyyah/matan',
                icon: 'M',
                image: '/menu-images/jurmiyyah/matan.png',
            },
            { label: 'Tuhfatus Saniyah', href: '/jurmiyyah/tuhfatus-saniyah', icon: 'T',
                image: '/menu-images/jurmiyyah/tuhfatus.png', },
            { label: 'Al Mumti', href: '/jurmiyyah/al-mumti', icon: 'A',
                image: '/menu-images/jurmiyyah/mumti.png', },
            { label: 'Mutammimah', href: '/jurmiyyah/mutammimah', icon: 'MU',
                image: '/menu-images/jurmiyyah/mutammimah.png', },
        ],
    },
    {
        title: 'Al-Arabiyyah Baina Yadaik (ABY)',
        items: [
            { label: 'ABY 1 A', href: '/aby/aby-1-a', icon: '1A' },
            { label: 'ABY 1 B', href: '/aby/aby-1-b', icon: '1B' },
            { label: 'ABY 2 A', href: '/aby/aby-2-a', icon: '2A' },
            { label: 'ABY 2 B', href: '/aby/aby-2-b', icon: '2B' },
        ],
    },
];
---

<section class="py-24 bg-white" id="belajar">
    <div class="container mx-auto px-6">
        <div class="flex flex-col md:flex-row md:items-end justify-between mb-16 gap-4">
            <div>
                <h2 class="text-4xl font-bold text-slate-900 mb-3">Akses Cepat Materi</h2>
                <p class="text-slate-500 text-lg">Pilih materi yang ingin Anda pelajari hari ini.</p>
            </div>
            <div class="flex gap-2">
                <span
                    class="flex items-center gap-1.5 text-xs font-bold text-emerald-700 bg-emerald-50 px-4 py-2 rounded-full border border-emerald-100"
                >
                    <span class="w-1.5 h-1.5 bg-emerald-500 rounded-full animate-pulse"></span>
                    12 Materi Tersedia
                </span>
            </div>
        </div>

        <div class="space-y-20">
            {
                categories.map((cat) => (
                    <div>
                        <h3 class="text-sm font-bold text-slate-400 uppercase tracking-[0.3em] mb-10 flex items-center gap-6">
                            {cat.title}
                            <div class="h-px bg-slate-200 flex-grow" />
                        </h3>
                        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-5">
                            {cat.items.map((item) => (
                                <a
                                    href={item.href}
                                    class="group flex flex-col bg-white rounded-2xl overflow-hidden border border-slate-100 shadow-sm hover:shadow-2xl hover:border-emerald-500/20 hover:-translate-y-2 transition-all duration-500"
                                >
                                    <div class="aspect-[3/4] overflow-hidden bg-slate-100 relative">
                                        {item.image ? (
                                            <img
                                                src={item.image}
                                                alt={item.label}
                                                class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"
                                            />
                                        ) : (
                                            <div class="w-full h-full flex flex-col items-center justify-center bg-slate-100 p-2">
                                                <div class="w-20 h-20 bg-white rounded-2xl flex items-center justify-center text-emerald-600 font-bold text-3xl shadow-sm mb-4 group-hover:scale-110 group-hover:rotate-3 transition-all duration-500">
                                                    {item.icon}
                                                </div>
                                                <div class="text-slate-300 font-bold text-xs uppercase tracking-widest">
                                                    No Preview
                                                </div>
                                            </div>
                                        )}
                                        <div class="absolute inset-0 bg-gradient-to-t from-slate-900/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex items-end p-6">
                                            <span class="text-white text-sm font-bold flex items-center gap-2">
                                                Mulai Belajar
                                                <svg
                                                    xmlns="http://www.w3.org/2000/svg"
                                                    class="h-4 w-4"
                                                    viewBox="0 0 20 20"
                                                    fill="currentColor"
                                                >
                                                    <path
                                                        fill-rule="evenodd"
                                                        d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z"
                                                        clip-rule="evenodd"
                                                    />
                                                </svg>
                                            </span>
                                        </div>
                                    </div>
                                    <div class="p-4">
                                        <h4 class="font-bold font-aref-ruqaa text-xl text-slate-900 group-hover:text-[#065f46] transition-colors mb-1">
                                            {item.label}
                                        </h4>
                                        <p class="text-sm text-slate-400">Klik untuk membuka modul</p>
                                    </div>
                                </a>
                            ))}
                        </div>
                    </div>
                ))
            }
        </div>
    </div>
</section>
