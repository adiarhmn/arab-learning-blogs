---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Tafsir - Pembelajaran Bahasa Arab & Tafsir">
    <div class="bg-gray-50 min-h-screen pb-20">
        <header class="bg-white border-b border-gray-100 py-8 lg:py-12 mb-8">
            <div class="container mx-auto px-6">
                <nav class="flex text-sm font-medium text-gray-500 mb-4 items-center gap-2">
                    <a href="/" class="hover:text-[#065f46]">Home</a>
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                    <span class="text-[#065f46]">Tafsir</span>
                </nav>
                <h1 class="text-3xl lg:text-4xl font-bold text-gray-900">Pembelajaran Tafsir</h1>
            </div>
        </header>

        <div class="container mx-auto px-6">
            <div class="bg-white p-8 lg:p-12 rounded-3xl shadow-sm border border-gray-100 text-center max-w-4xl mx-auto">
                <div class="w-20 h-20 bg-emerald-50 text-[#065f46] rounded-full flex items-center justify-center mx-auto mb-6">
                    <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path></svg>
                </div>
                <h2 class="text-3xl font-bold text-gray-900 mb-4">Materi Tafsir Segera Hadir</h2>
                <p class="text-gray-600 leading-relaxed text-lg mb-8">
                    Kami sedang mempersiapkan kurikulum Tafsir Al-Qur'an yang mendalam dan terstruktur untuk Anda. 
                    Nantikan pembaruan selanjutnya di platform ini.
                </p>
                <a href="/" class="inline-block bg-[#065f46] text-white px-8 py-4 rounded-xl font-bold hover:bg-[#044a37] transition-all">
                    Kembali ke Beranda
                </a>
            </div>
        </div>
    </div>
</Layout>
