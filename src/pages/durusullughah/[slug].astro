---
import Layout from '../../layouts/Layout.astro';
import Button from '../../components/ui/Button.astro';

export function getStaticPaths() {
    return [
        { params: { slug: 'jilid-1' } },
        { params: { slug: 'jilid-2' } },
        { params: { slug: 'jilid-3' } },
        { params: { slug: 'jilid-4' } },
    ];
}

const { slug } = Astro.params;

const lessons = {
    'jilid-1': {
        title: 'Durusullughah Jilid 1',
        description:
            'Pelajari dasar-dasar bahasa Arab dari nol. Jilid ini fokus pada pengenalan kata benda (Isim), kata tunjuk, dan struktur kalimat sederhana yang digunakan sehari-hari.',
        youtubeId: '8e5Nmpy8Zmw',
    },
    'jilid-2': {
        title: 'Durusullughah Jilid 2',
        description:
            "Melanjutkan pemahaman tata bahasa Arab dengan fokus pada kata kerja (Fi'il), perubahan bentuk kata (Shorof), dan kosa kata yang lebih luas.",
        youtubeId: '8e5Nmpy8Zmw',
    },
    'jilid-3': {
        title: 'Durusullughah Jilid 3',
        description:
            'Memasuki tahap menengah di mana santri mulai belajar menganalisis kalimat yang lebih panjang dan teks-teks literatur Arab dasar.',
        youtubeId: '8e5Nmpy8Zmw',
    },
    'jilid-4': {
        title: 'Durusullughah Jilid 4',
        description:
            'Tahap lanjut yang mempersiapkan santri untuk memahami teks-teks klasik, kitab tafsir, dan dasar-dasar ilmu Balaghah.',
        youtubeId: '8e5Nmpy8Zmw',
    },
};

const lesson = lessons[slug as keyof typeof lessons];

if (!lesson) {
    return Astro.redirect('/404');
}
---

<Layout title={`${lesson.title} - Pembelajaran Bahasa Arab & Tafsir`}>
    <div class="bg-gray-50 min-h-screen pb-20">
        <!-- Breadcrumbs & Header -->
        <header class="bg-white border-b border-gray-100 py-8 lg:py-12 mb-8">
            <div class="container mx-auto px-6">
                <nav class="flex text-sm font-medium text-gray-500 mb-4 items-center gap-2">
                    <a href="/" class="hover:text-[#065f46]">Home</a>
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"
                        ><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"
                        ></path></svg
                    >
                    <span class="text-gray-400">Bahasa Arab</span>
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"
                        ><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"
                        ></path></svg
                    >
                    <span class="text-[#065f46]">{lesson.title}</span>
                </nav>
                <h1 class="text-3xl lg:text-4xl font-bold text-gray-900 font-aref-ruqaa">{lesson.title}</h1>
            </div>
        </header>

        <div class="container mx-auto px-6 grid grid-cols-1 lg:grid-cols-3 gap-5">
            <!-- Main Content -->
            <div class="lg:col-span-2 space-y-8">
                <!-- Video Container -->
                <div class="bg-black rounded-3xl overflow-hidden shadow-2xl relative group">
                    <div class="aspect-video">
                        <iframe class="w-full h-full" src="https://www.youtube.com/embed/8e5Nmpy8Zmw" allowfullscreen>
                        </iframe>
                    </div>
                </div>

                <!-- Description -->
                <div class="bg-white p-8 lg:p-10 rounded-3xl shadow-sm border border-gray-100">
                    <h2 class="text-2xl font-bold text-gray-900 mb-4">Tentang Pelajaran Ini</h2>
                    <p class="text-gray-600 leading-relaxed text-lg mb-8">
                        {lesson.description}
                    </p>
                </div>
            </div>

            <!-- Sidebar -->
            <div class="space-y-6">
                <div class="bg-[#065f46] p-8 rounded-3xl text-white shadow-xl shadow-emerald-900/10">
                    <h3 class="text-xl font-bold mb-4">Navigasi Jilid</h3>
                    <p class="text-emerald-100/80 mb-6 text-sm">
                        Gunakan tombol di bawah untuk berpindah antar jilid Durusullughah dengan cepat.
                    </p>
                    <div class="space-y-3">
                        {
                            ['jilid-1', 'jilid-2', 'jilid-3', 'jilid-4'].map((s) => (
                                <a
                                    href={`/durusullughah/${s}`}
                                    class={`block w-full text-center py-3 rounded-xl font-semibold transition-all ${slug === s ? 'bg-white text-[#065f46] shadow-lg scale-105' : 'bg-[#054a37] text-white hover:bg-[#043d2e]'}`}
                                >
                                    Durusullughah {s.replace('-', ' ').toUpperCase()}
                                </a>
                            ))
                        }
                    </div>
                </div>

                <div class="bg-white p-8 rounded-3xl border border-gray-100 shadow-sm text-center">
                    <div class="w-16 h-16 bg-gold-accent/10 rounded-full flex items-center justify-center mx-auto mb-4">
                        <svg class="w-8 h-8 text-[#d4af37]" fill="none" stroke="currentColor" viewBox="0 0 24 24"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"
                            ></path></svg
                        >
                    </div>
                    <h4 class="font-bold text-gray-900 mb-2">Butuh Bantuan?</h4>
                    <p class="text-sm text-gray-500 mb-6">
                        Jika Anda mengalami kesulitan memahami materi, silakan hubungi pengajar atau akses forum diskusi
                        santri.
                    </p>
                    <Button variant="outline" class="w-full text-sm py-2"> Hubungi Pengajar </Button>
                </div>
            </div>
        </div>
    </div>
</Layout>
